APP_NAME=Study Sprint Generator
APP_ENV=development
DATABASE_URL=postgresql+psycopg://postgres:postgres@localhost:5432/study_sprint
# Quick local fallback when PostgreSQL is unavailable:
# DATABASE_URL=sqlite:///E:/Dasan/appthird/backend/study_sprint.db
CORS_ORIGINS=["http://localhost:3000"]
MAX_UPLOAD_SIZE_MB=200
ENABLE_HISTORY=false

AI_PROVIDER=mock
AI_BASE_URL=https://api.openai.com/v1
AI_API_KEY=
AI_MODEL=gpt-4.1-mini

# Install backend/requirements-audio.txt for local faster-whisper support,
# or switch to WHISPER_BACKEND=openai to use a compatible remote API.
WHISPER_BACKEND=local
WHISPER_MODEL_SIZE=base